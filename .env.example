APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# log by default: a fresh clone with no Mailpit running should write mail to
# the log, not fail every send. Switch to smtp once a mailbox is up.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

# Envelope sender for all outgoing mail. Stays the platform's address even
# when sending on behalf of a tenant — SPF/DKIM are published for our domain.
# A tenant only supplies the display name and reply-to (tenants.mail_from_name,
# tenants.mail_reply_to).
MAIL_FROM_ADDRESS="noreply@droidshop.cz"
MAIL_FROM_NAME="DroidShop"

# Platform billing (wave 1.7)
BILLING_TRIAL_DAYS=14
BILLING_GRACE_DAYS=7
BILLING_SUBSCRIPTION_DRIVER=null
BILLING_COMPANY_NAME="Miroslav Opletal"
BILLING_COMPANY_ICO=
BILLING_COMPANY_DIC=
BILLING_VAT_RATE=21

# Stripe (wave 1.8)
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIG=

# Custom domains / auto TLS (wave 2.1)
PLATFORM_SERVER_IP=
PLATFORM_EDGE_HOST=edge.droidshop.cz

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
